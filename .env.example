# OpenAI-compatible API used for account analysis.
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-5.4-mini"

# Supabase/Postgres connection used by migrations, worker writes, and the
# Vercel server route. Prefer SUPABASE_DB_URL; DATABASE_URL is a fallback alias.
SUPABASE_DB_URL=""
DATABASE_URL=""

# Optional public Supabase fallback. Use only when these point to the same
# Supabase project as SUPABASE_DB_URL.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Worker defaults.
DETECT_POLL_SECONDS="20"
DETECT_TARGET_TWEETS="50"
DETECT_MAX_X_PAGES="10"

# Optional: raises GitHub API rate limits for repository analysis.
GITHUB_TOKEN=""
